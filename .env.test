# Test environment configuration for trace query rewrite pipeline
# Used to validate wildcard pattern generation for Datadog trace queries

DATADOG_API_URL=https://api.datadoghq.com
DATADOG_ENV=test
SERVICE_NAME=sinatra
RESOURCE_NAME_SAMPLE=GET /posts/{post_id}/guest-order
LOG_LEVEL=DEBUG
MAX_RETRY_ATTEMPTS=3
RETRY_INTERVAL_SECONDS=300
LLM_FUZZY_MATCH_ENABLED=true
