# =============================================================================
# Test Environment Configuration for Datadog Trace Utility
# =============================================================================
# Purpose: Provides mock/placeholder environment variables so that trace_util.py
# and related modules (including _process_datadog_trace_tag_filter_value()) can
# be exercised locally without live Datadog credentials.
#
# Usage:
#   source .env.test   # or load via python-dotenv / direnv
#
# Context: This file supports local reproduction of the wildcard pattern
# mismatch bug in _process_datadog_trace_tag_filter_value(), where single-char
# wildcard `?` should be replaced with multi-char wildcard `*` for
# resource_name matching on Sinatra service endpoints.
# =============================================================================

# ---------------------
# Datadog API Credentials (mock / placeholder values)
# ---------------------
DD_API_KEY=PLACEHOLDER_API_KEY_FOR_TESTING
DD_APP_KEY=PLACEHOLDER_APP_KEY_FOR_TESTING

# ---------------------
# Datadog Site & Environment
# ---------------------
DD_SITE=datadoghq.com
DD_ENV=prod

# ---------------------
# Service Configuration
# ---------------------
DD_SERVICE=sinatra
DD_VERSION=1.0.0

# ---------------------
# Trace Query Defaults
# ---------------------
# The resource name pattern used to reproduce the wildcard mismatch bug.
# The faulty behaviour uses `?` (single-char wildcard); the fix should use `*`.
DD_TRACE_RESOURCE_PATTERN=GET /api/v1/endpoint/*
DD_TRACE_QUERY_TIMEFRAME=1h

# ---------------------
# LLM Fuzzy Match Fallback
# ---------------------
LLM_FUZZY_MATCH_ENABLED=true
LLM_FUZZY_MATCH_MODEL=mock
LLM_FUZZY_MATCH_TIMEOUT_SECONDS=5

# ---------------------
# General Test Settings
# ---------------------
LOG_LEVEL=DEBUG
TESTING=true
