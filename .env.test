# =============================================================================
# Test Environment Configuration
# =============================================================================
# This file provides placeholder environment variables for running tests
# against the Datadog trace alert investigation pipeline locally.
#
# Usage:
#   cp .env.test .env
#   # Then run your tests as usual, e.g.:
#   pytest tests/
#
# WARNING: Never commit real credentials. This file contains only placeholder
# values suitable for a test/mock environment.
# =============================================================================

# ---------------------
# Datadog API Credentials
# ---------------------
DD_API_KEY=test_api_key_placeholder_00000000000000000000000000000000
DD_APP_KEY=test_app_key_placeholder_0000000000000000000000000000000000000000

# ---------------------
# Datadog Environment
# ---------------------
DD_ENV=test
DD_SITE=datadoghq.com

# ---------------------
# Service Configuration
# ---------------------
DD_SERVICE=bacca-executor
DD_SERVICE_NAME=bacca-executor
DD_VERSION=0.0.0-test

# ---------------------
# Trace Query Settings
# ---------------------
# Controls behaviour of trace_util.py and trace_action_util.py when
# rewriting metric queries into trace queries.
DD_TRACE_QUERY_TIMEOUT=30
DD_TRACE_ANALYTICS_ENABLED=true

# ---------------------
# Datadog Trace Alert Step Runner
# ---------------------
# Used by datadog_trace_alert_step_runner.py to configure the investigation
# pipeline.
DD_TRACE_ALERT_ENABLED=true
DD_TRACE_ALERT_DRY_RUN=true

# ---------------------
# Tag Filter / Wildcard Settings
# ---------------------
# Relevant to _process_datadog_trace_tag_filter_value() wildcard handling.
DD_TRACE_TAG_FILTER_WILDCARD_ENABLED=true

# ---------------------
# Logging
# ---------------------
LOG_LEVEL=DEBUG
