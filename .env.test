# =============================================================================
# Test Environment Configuration
# =============================================================================
# This file provides placeholder/mock values for running tests against the
# trace investigation pipeline components (trace_util.py,
# trace_action_util.py, datadog_trace_alert_step_runner.py) without requiring
# real credentials.
#
# Usage:
#   Copy this file or source it before running the test suite:
#     set -a; source .env.test; set +a
#     pytest tests/
# =============================================================================

# -----------------------------------------------------------------------------
# Datadog API Credentials (mock values for testing)
# -----------------------------------------------------------------------------
DD_API_KEY=test_api_key_000000000000000000000000
DD_APP_KEY=test_app_key_0000000000000000000000000000000000000000
DD_SITE=datadoghq.com

# -----------------------------------------------------------------------------
# Datadog Trace Query Configuration
# -----------------------------------------------------------------------------
# Default service used when rewriting metric queries into trace queries.
DD_SERVICE=bacca-executor
# Default environment tag for trace search.
DD_ENV=test
# Retention filter to use for trace queries during tests.
DD_TRACE_RETENTION_FILTER=*

# -----------------------------------------------------------------------------
# Trace Investigation Pipeline Settings
# -----------------------------------------------------------------------------
# Maximum number of traces to fetch per query during tests.
TRACE_QUERY_LIMIT=100
# Timeout (in seconds) for individual Datadog API requests.
TRACE_API_TIMEOUT=30
# Toggle verbose/debug logging for trace utilities.
TRACE_DEBUG=true

# -----------------------------------------------------------------------------
# Wildcard Pattern Generation
# -----------------------------------------------------------------------------
# Delimiter used by _process_datadog_trace_tag_filter_value() when splitting
# tag values for wildcard expansion.
TRACE_TAG_FILTER_DELIMITER=.
# When true, enables wildcard pattern generation in tag filter processing.
TRACE_WILDCARD_ENABLED=true

# -----------------------------------------------------------------------------
# Service-Level Configuration
# -----------------------------------------------------------------------------
# Name of the executor service under test.
SERVICE_NAME=bacca-executor
# Log level for test runs.
LOG_LEVEL=DEBUG
# Disable external network calls during unit tests.
MOCK_EXTERNAL_CALLS=true
