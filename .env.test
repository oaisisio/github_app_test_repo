# =============================================================================
# .env.test — Test environment configuration for bacca-executor
# =============================================================================
# This file provides placeholder values for running the Datadog trace
# investigation pipeline locally. Copy to .env for local development and
# replace placeholder values with real credentials as needed.
#
# IMPORTANT: Never commit real secrets. Use .env.test.example as the
# committed reference and keep your actual .env out of version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Datadog API Credentials
# ---------------------------------------------------------------------------
# Obtain these from https://app.datadoghq.com/organization-settings/api-keys
DATADOG_API_KEY=placeholder_datadog_api_key
DATADOG_APP_KEY=placeholder_datadog_app_key

# ---------------------------------------------------------------------------
# Datadog Environment & Service Configuration
# ---------------------------------------------------------------------------
DD_ENV=test
DD_SERVICE=bacca-executor
DD_SITE=datadoghq.com

# ---------------------------------------------------------------------------
# Trace Investigation Pipeline Settings
# ---------------------------------------------------------------------------
# Maximum number of traces to fetch per query
DD_TRACE_QUERY_LIMIT=100

# Timeout in seconds for trace API requests
DD_TRACE_QUERY_TIMEOUT=30

# Enable verbose logging for trace investigation debugging
DD_TRACE_DEBUG=true

# ---------------------------------------------------------------------------
# Trace Query Rewrite / Filter Settings
# ---------------------------------------------------------------------------
# Controls how wildcard characters in route patterns are handled during
# trace tag filtering. Relevant to _process_datadog_trace_tag_filter_value().
#
# Example parameterized route patterns that the pipeline must handle:
#   GET /posts/:post_id/guest-order
#   PUT /users/:user_id/settings
DD_TRACE_WILDCARD_CHAR=*
DD_TRACE_FILTER_SERVICE=bacca-executor
DD_TRACE_FILTER_ENV=test

# ---------------------------------------------------------------------------
# General Application Settings
# ---------------------------------------------------------------------------
LOG_LEVEL=DEBUG
NODE_ENV=test
