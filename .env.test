# =============================================================================
# Test Environment Configuration
# =============================================================================
# This file provides mock/stub environment variables for running tests against
# the Datadog trace investigation pipeline components:
#   - trace_util.py
#   - trace_action_util.py
#   - datadog_trace_alert_step_runner.py
#
# IMPORTANT: Do NOT put real credentials in this file. Use placeholder values
# only. If you need real credentials for local development, copy this file to
# .env.local (which is gitignored) and fill in actual values there.
# =============================================================================

# -----------------------------------------------------------------------------
# Datadog API Configuration
# -----------------------------------------------------------------------------
DD_API_KEY=test_dd_api_key_placeholder_00000000000000000000
DD_APP_KEY=test_dd_app_key_placeholder_00000000000000000000
DD_API_URL=https://api.datadoghq.com
DD_SITE=datadoghq.com

# -----------------------------------------------------------------------------
# Service Configuration
# -----------------------------------------------------------------------------
DD_SERVICE_NAME=bacca-executor
DD_ENV=test
DD_VERSION=0.0.0-test

# -----------------------------------------------------------------------------
# Trace Investigation Pipeline Settings
# -----------------------------------------------------------------------------
# The trace query pattern used for filtering spans. Use '*' for wildcard
# matching (not '?' which caused the production pattern mismatch issue).
TRACE_QUERY_PATTERN=service:bacca-executor AND env:test AND resource_name:*
TRACE_SEARCH_WINDOW_SECONDS=3600
TRACE_MAX_RESULTS=100

# -----------------------------------------------------------------------------
# Alert Step Runner Configuration
# -----------------------------------------------------------------------------
ALERT_THRESHOLD_ERROR_RATE=0.05
ALERT_THRESHOLD_LATENCY_P99_MS=5000
ALERT_EVALUATION_WINDOW_MINUTES=15
ALERT_NOTIFICATION_CHANNEL=test-alerts

# -----------------------------------------------------------------------------
# Test-Specific Settings
# -----------------------------------------------------------------------------
# Set to 'true' to enable verbose logging during test runs
TEST_VERBOSE=false
# Set to 'true' to record HTTP interactions for replay in tests
TEST_RECORD_MODE=false
# Base URL override for mocked Datadog API calls
TEST_DD_API_BASE_URL=http://localhost:8080
