# =============================================================================
# .env.test — Environment variables for testing the Datadog trace query
# rewrite pipeline (trace_util.py, trace_action_util.py,
# datadog_trace_alert_step_runner.py).
#
# FOR TESTING PURPOSES ONLY — do NOT put real credentials in this file.
# Copy this file to .env.test.local and fill in real values if needed for
# integration tests; .env.test.local should be git-ignored.
# =============================================================================

# ---------------------------------------------------------------------------
# Datadog API credentials (use dummy values for unit tests)
# ---------------------------------------------------------------------------
DATADOG_API_KEY=placeholder_api_key_for_testing
DATADOG_APP_KEY=placeholder_app_key_for_testing

# Datadog site to send requests to
DATADOG_SITE=datadoghq.com

# ---------------------------------------------------------------------------
# Datadog agent / service identifiers used in span queries
# ---------------------------------------------------------------------------
DD_ENV=test
DD_SERVICE=bacca-executor

# ---------------------------------------------------------------------------
# Trace query rewrite settings
# ---------------------------------------------------------------------------
# Default resource name pattern applied when rewriting metric queries to
# trace queries for parameterized Sinatra-style endpoints.
DD_TRACE_RESOURCE_NAME_PATTERN=GET /api/v1/users/*

# The environment tag value passed to the Datadog trace search API
DD_TRACE_ENV_TAG=test

# ---------------------------------------------------------------------------
# Optional: additional service / endpoint config for integration tests
# ---------------------------------------------------------------------------
# DD_TRACE_ENDPOINT_URL=https://api.datadoghq.com
# DD_TRACE_QUERY_TIMEOUT_SECONDS=30
# DD_TRACE_MAX_RETRIES=3
