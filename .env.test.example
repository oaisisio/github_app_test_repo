# =============================================================================
# bacca-executor: Test Environment Configuration
# =============================================================================
# This is a TEMPLATE file with placeholder values for running the trace
# investigation pipeline locally. Copy this file to `.env.test` and replace
# the placeholder values with real credentials before use.
#
#   cp .env.test.example .env.test
#
# IMPORTANT: Never commit `.env.test` with real secrets.
# =============================================================================

# ---------------------
# General Service Settings
# ---------------------
ENV=test
SERVICE_NAME=bacca-executor
LOG_LEVEL=DEBUG

# ---------------------
# Datadog API Credentials
# ---------------------
# Obtain these from your Datadog organization settings:
#   https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=your_datadog_api_key_here
DD_APP_KEY=your_datadog_app_key_here
DD_SITE=datadoghq.com

# ---------------------
# Datadog Trace Investigation
# ---------------------
# Default time window (in minutes) for trace queries
DD_TRACE_QUERY_WINDOW_MINUTES=60
# Maximum number of traces to retrieve per query
DD_TRACE_MAX_RESULTS=100

# ---------------------
# Executor Configuration
# ---------------------
EXECUTOR_TIMEOUT_SECONDS=300
EXECUTOR_MAX_RETRIES=3
EXECUTOR_RETRY_DELAY_SECONDS=5

# ---------------------
# Alert Pipeline Settings
# ---------------------
ALERT_PIPELINE_ENABLED=true
ALERT_PIPELINE_DRY_RUN=true
