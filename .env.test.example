# =============================================================================
# Test Environment Configuration — Example Template
# =============================================================================
# Copy this file to .env.test and fill in values as needed.
# See .env.test for the full set of placeholder values used in CI/testing.
#
# To use real credentials locally, copy to .env.local (gitignored).
# =============================================================================

DD_API_KEY=<your-datadog-api-key>
DD_APP_KEY=<your-datadog-app-key>
DD_API_URL=https://api.datadoghq.com
DD_SITE=datadoghq.com

DD_SERVICE_NAME=bacca-executor
DD_ENV=test
DD_VERSION=0.0.0-test

TRACE_QUERY_PATTERN=service:bacca-executor AND env:test AND resource_name:*
TRACE_SEARCH_WINDOW_SECONDS=3600
TRACE_MAX_RESULTS=100

ALERT_THRESHOLD_ERROR_RATE=0.05
ALERT_THRESHOLD_LATENCY_P99_MS=5000
ALERT_EVALUATION_WINDOW_MINUTES=15
ALERT_NOTIFICATION_CHANNEL=test-alerts

TEST_VERBOSE=false
TEST_RECORD_MODE=false
TEST_DD_API_BASE_URL=http://localhost:8080
