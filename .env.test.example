# =============================================================================
# .env.test.example — Template for test environment configuration
# =============================================================================
# Copy this file to .env.test (or .env) and fill in real values where needed.
#
#   cp .env.test.example .env.test
#
# All values below are safe placeholders. Variables marked [REQUIRED] must be
# set to real values before the trace investigation pipeline will work.
# =============================================================================

# ---------------------------------------------------------------------------
# Datadog API Credentials  [REQUIRED]
# ---------------------------------------------------------------------------
DATADOG_API_KEY=<your-datadog-api-key>
DATADOG_APP_KEY=<your-datadog-app-key>

# ---------------------------------------------------------------------------
# Datadog Environment & Service Configuration
# ---------------------------------------------------------------------------
DD_ENV=test
DD_SERVICE=bacca-executor
DD_SITE=datadoghq.com

# ---------------------------------------------------------------------------
# Trace Investigation Pipeline Settings
# ---------------------------------------------------------------------------
DD_TRACE_QUERY_LIMIT=100
DD_TRACE_QUERY_TIMEOUT=30
DD_TRACE_DEBUG=true

# ---------------------------------------------------------------------------
# Trace Query Rewrite / Filter Settings
# ---------------------------------------------------------------------------
DD_TRACE_WILDCARD_CHAR=*
DD_TRACE_FILTER_SERVICE=bacca-executor
DD_TRACE_FILTER_ENV=test

# ---------------------------------------------------------------------------
# General Application Settings
# ---------------------------------------------------------------------------
LOG_LEVEL=DEBUG
NODE_ENV=test
