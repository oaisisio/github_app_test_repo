# =============================================================================
# Environment variables for local testing of Datadog trace utilities
# =============================================================================
#
# Usage:
#   1. Copy this file:  cp .env.test.example .env.test
#   2. Replace placeholder values with real credentials (if needed for
#      integration tests).
#   3. Run the trace utility tests:
#        pytest tests/ -k "trace"
#
# WARNING: Never commit .env.test with real secrets to version control.
# =============================================================================

# --------------- Datadog API credentials ---------------
# Required by trace_util.py and datadog_trace_alert_step_runner.py
DATADOG_API_KEY=REPLACE_WITH_YOUR_DATADOG_API_KEY
DATADOG_APP_KEY=REPLACE_WITH_YOUR_DATADOG_APP_KEY

# Datadog site/region (default: datadoghq.com)
DATADOG_SITE=datadoghq.com

# --------------- Service / environment identifiers ---------------
# Used by _process_datadog_trace_tag_filter_value() and related helpers
ENV=test
SERVICE_NAME=sinatra

# --------------- Trace query settings ---------------
# Optional overrides used by trace_action_util.py
TRACE_QUERY_TIME_RANGE_MINUTES=60
TRACE_QUERY_LIMIT=100
