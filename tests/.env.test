# Test environment for debugging trace query rewrite issues
# Related incident: c6d429775f2e4822
# Customer: 92646e48-3ca7-4442-9ca4-61af3354d3fb

# Datadog configuration
DD_SERVICE=sinatra
DD_ENV=prod
DD_RESOURCE_NAME=GET /posts/{post_id}/guest-order

# Metric tag value (as it appears in the metric monitor)
METRIC_TAG_VALUE=GET_/posts/_post_id/guest-order

# Expected trace query after rewrite
EXPECTED_TRACE_QUERY=service:sinatra AND resource_name:GET?/posts/?post?id/guest?order AND env:prod

# Actual trace resource name (what exists in Datadog traces)
ACTUAL_TRACE_RESOURCE_NAME=GET /posts/{post_id}/guest-order

# Debug flags
DEBUG_TRACE_REWRITE=true
LOG_LEVEL=DEBUG
