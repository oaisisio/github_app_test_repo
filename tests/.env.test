# =============================================================================
# Test Environment Configuration
# =============================================================================
# This file provides mock/placeholder values for running tests against the
# Datadog trace alert investigation pipeline (bacca-executor).
#
# These values are NOT real credentials. They exist so that unit and integration
# tests can execute without hitting production APIs.
# =============================================================================

# ---------------------------------------------------------------------------
# Datadog API credentials (mock values for testing)
# ---------------------------------------------------------------------------
DD_API_KEY=test_api_key_000000000000000000000000
DD_APP_KEY=test_app_key_000000000000000000000000
DD_API_URL=https://api.datadoghq.com
DD_SITE=datadoghq.com

# ---------------------------------------------------------------------------
# Service configuration
# ---------------------------------------------------------------------------
DD_SERVICE_NAME=sinatra
DD_ENV=test
DD_ENV_TAG=env:test
DD_SERVICE_TAG=service:sinatra

# ---------------------------------------------------------------------------
# Trace query defaults
# ---------------------------------------------------------------------------
DD_TRACE_QUERY_TIME_RANGE=3600
DD_TRACE_QUERY_MAX_RESULTS=100
DD_TRACE_SEARCH_DEFAULT_QUERY=service:sinatra env:test

# ---------------------------------------------------------------------------
# Tag filter configuration
# ---------------------------------------------------------------------------
DD_TRACE_TAG_FILTER_ENABLED=true
DD_TRACE_TAG_FILTER_WILDCARD_SUPPORT=true

# ---------------------------------------------------------------------------
# LLM / fuzzy-match configuration (used by trace_action_util)
# ---------------------------------------------------------------------------
LLM_PROVIDER=mock
LLM_MODEL=test-model
LLM_API_KEY=test_llm_api_key_placeholder
LLM_FUZZY_MATCH_THRESHOLD=0.8
LLM_FUZZY_MATCH_MAX_CANDIDATES=5

# ---------------------------------------------------------------------------
# Alert step runner configuration
# ---------------------------------------------------------------------------
ALERT_RUNNER_DRY_RUN=true
ALERT_RUNNER_TIMEOUT_SECONDS=30
ALERT_RUNNER_RETRY_COUNT=0

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=DEBUG
LOG_FORMAT=json
