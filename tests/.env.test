# ============================================================
# Test environment variables for local debugging of the
# Datadog trace query rewrite pipeline.
#
# Usage:
#   export $(grep -v '^#' tests/.env.test | xargs)
#   # or with python-dotenv:
#   from dotenv import load_dotenv; load_dotenv("tests/.env.test")
#
# DO NOT commit real credentials. Replace placeholder values
# with your own keys only in your local environment.
# ============================================================

# ------------------------------------
# Datadog API credentials (placeholders)
# ------------------------------------
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_APP_KEY=your_datadog_app_key_here
DATADOG_SITE=datadoghq.com

# ------------------------------------
# Runtime environment
# ------------------------------------
ENV=test

# ------------------------------------
# Failing scenario: wildcard pattern mismatch in bacca-executor
#
# Root cause: _process_datadog_trace_tag_filter_value() converts
# underscores/hyphens to '?' wildcards, producing patterns like:
#   GET?/posts/?post?id/guest?order
# which fail to match actual trace spans with resource names like:
#   GET /posts/{post_id}/guest-order
# ------------------------------------

# Service under test
TEST_SERVICE_NAME=sinatra

# Raw metric tag value as stored in Datadog (underscores replace
# spaces, hyphens, and braces in the original resource name)
TEST_METRIC_TAG_VALUE=GET_/posts/_post_id/guest-order

# The actual trace resource_name that should be matched
TEST_EXPECTED_RESOURCE_NAME=GET /posts/{post_id}/guest-order

# Datadog environment tag for the query scope
TEST_DD_ENV=prod

# Incident and customer identifiers for the reproducer scenario
TEST_INCIDENT_ID=c6d429775f2e4822
TEST_CUSTOMER_ID=92646e48-3ca7-4442-9ca4-61af3354d3fb
