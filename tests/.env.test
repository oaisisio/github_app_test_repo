DATADOG_SERVICE=sinatra
DATADOG_ENV=prod
TEST_METRIC_TAG_VALUE=GET_/posts/_post_id/guest-order
TEST_EXPECTED_TRACE_RESOURCE_NAME=GET /posts/{post_id}/guest-order
TEST_GENERATED_WILDCARD_PATTERN=GET?/posts/?post?id/guest?order

# This demonstrates the mismatch:
# Pattern 'GET?/posts/?post?id/guest?order' uses ? (single-char wildcard)
# But actual trace resource_name 'GET /posts/{post_id}/guest-order' has different char counts
# {post_id} = 9 chars vs ?post?id = 8 chars — pattern cannot match
