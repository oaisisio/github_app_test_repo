# ============================================================
# Fixture: trace_rewrite_debug.env
#
# Static fixture capturing the exact input/output values for the
# wildcard pattern mismatch bug in the Datadog trace query rewrite
# pipeline (bacca-executor service).
#
# Load this fixture in unit or integration tests to reproduce the
# failure deterministically without hitting production infrastructure:
#
#   Python example:
#     import os
#     from pathlib import Path
#     from dotenv import dotenv_values
#
#     fixture = dotenv_values(
#         Path(__file__).parent / "fixtures" / "trace_rewrite_debug.env"
#     )
#
# Shell example:
#   set -a; source tests/fixtures/trace_rewrite_debug.env; set +a
# ============================================================

# ------------------------------------
# Scenario metadata
# ------------------------------------
SCENARIO_DESCRIPTION=Wildcard pattern mismatch: _process_datadog_trace_tag_filter_value generates incorrect patterns
SCENARIO_SERVICE=sinatra
SCENARIO_DD_ENV=prod
SCENARIO_INCIDENT_ID=c6d429775f2e4822
SCENARIO_CUSTOMER_ID=92646e48-3ca7-4442-9ca4-61af3354d3fb

# ------------------------------------
# Input: metric tag value as returned by the Datadog metrics API
# Underscores encode spaces, hyphens encode literal hyphens, and
# curly-brace tokens like {post_id} are collapsed to _post_id.
# ------------------------------------
INPUT_METRIC_TAG_VALUE=GET_/posts/_post_id/guest-order

# ------------------------------------
# Buggy intermediate output produced by
# _process_datadog_trace_tag_filter_value() — each underscore and
# hyphen is blindly replaced with the '?' wildcard, causing the
# filter query to match nothing.
# ------------------------------------
BUGGY_WILDCARD_PATTERN=GET?/posts/?post?id/guest?order

# ------------------------------------
# Correct/expected trace resource_name that the rewrite pipeline
# should ultimately resolve to and match against.
# ------------------------------------
EXPECTED_RESOURCE_NAME=GET /posts/{post_id}/guest-order

# ------------------------------------
# LLM fuzzy-match fallback input (the string passed to the model
# when the direct wildcard lookup yields zero results)
# ------------------------------------
LLM_FUZZY_INPUT=GET_/posts/_post_id/guest-order
LLM_FUZZY_EXPECTED_OUTPUT=GET /posts/{post_id}/guest-order
