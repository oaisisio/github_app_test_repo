# =============================================================================
# Environment Variable Reference — bacca-executor
# =============================================================================
# Copy this file to `.env` (local development) or `tests/.env.test` (testing)
# and fill in the values appropriate for your environment.
# =============================================================================

# ---------------------------------------------------------------------------
# Datadog API credentials
# ---------------------------------------------------------------------------
# Required. Obtain from https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=<your-datadog-api-key>
DD_APP_KEY=<your-datadog-app-key>
# Optional. Defaults to https://api.datadoghq.com
DD_API_URL=https://api.datadoghq.com
# Optional. Defaults to datadoghq.com
DD_SITE=datadoghq.com

# ---------------------------------------------------------------------------
# Service configuration
# ---------------------------------------------------------------------------
# The primary service name being investigated (e.g., sinatra, rails, express)
DD_SERVICE_NAME=sinatra
# Deployment environment: prod, staging, test, etc.
DD_ENV=prod
# Datadog-style tag values used in trace queries
DD_ENV_TAG=env:prod
DD_SERVICE_TAG=service:sinatra

# ---------------------------------------------------------------------------
# Trace query defaults
# ---------------------------------------------------------------------------
# Time range in seconds for trace search queries (default: 3600 = 1 hour)
DD_TRACE_QUERY_TIME_RANGE=3600
# Maximum number of trace results to return per query
DD_TRACE_QUERY_MAX_RESULTS=100
# Default search query template
DD_TRACE_SEARCH_DEFAULT_QUERY=service:sinatra env:prod

# ---------------------------------------------------------------------------
# Tag filter configuration
# Used by _process_datadog_trace_tag_filter_value() in trace_util.py
# ---------------------------------------------------------------------------
# Enable or disable tag-based trace filtering
DD_TRACE_TAG_FILTER_ENABLED=true
# Enable wildcard pattern support in tag filter values
DD_TRACE_TAG_FILTER_WILDCARD_SUPPORT=true

# ---------------------------------------------------------------------------
# LLM / fuzzy-match configuration
# Used by trace_action_util.py for fuzzy matching of trace attributes
# ---------------------------------------------------------------------------
# LLM provider: openai, anthropic, mock (use "mock" for testing)
LLM_PROVIDER=openai
# Model identifier
LLM_MODEL=gpt-4
# API key for the LLM provider
LLM_API_KEY=<your-llm-api-key>
# Minimum similarity score (0.0–1.0) to accept a fuzzy match
LLM_FUZZY_MATCH_THRESHOLD=0.8
# Maximum number of candidate matches to evaluate
LLM_FUZZY_MATCH_MAX_CANDIDATES=5

# ---------------------------------------------------------------------------
# Alert step runner configuration
# Used by datadog_trace_alert_step_runner.py
# ---------------------------------------------------------------------------
# When true, the runner logs actions without executing them
ALERT_RUNNER_DRY_RUN=false
# Maximum seconds to wait for a single step to complete
ALERT_RUNNER_TIMEOUT_SECONDS=60
# Number of automatic retries on transient failures
ALERT_RUNNER_RETRY_COUNT=3

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log output format: json, text
LOG_FORMAT=json
