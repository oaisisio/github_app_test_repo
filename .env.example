# Application
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database (RDS/PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/ltpayments_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ltpayments_dev
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# GraphQL / Hive Gateway
HIVE_GATEWAY_URL=http://localhost:4001/graphql
GRAPHQL_MESH_URL=http://localhost:4002/graphql

# Internal Service URLs
MONOLITH_SERVICE_URL=http://localhost:3000
PROFILES_SERVICE_URL=http://localhost:4003
LINKTREE_BACKEND_URL=http://localhost:4004

# Auth / Security
JWT_SECRET=your_jwt_secret_here
API_KEY=your_internal_api_key_here

# Feature Flags
FEATURE_FLAG_SERVICE_URL=http://localhost:4005
FEATURE_FLAG_API_KEY=your_feature_flag_api_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
