# =============================================================================
# ltpayments (payments-service) - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# Do NOT commit your .env file — it may contain real secrets.
# =============================================================================

# Application
NODE_ENV=development
PORT=4000
SERVICE_NAME=ltpayments

# Database (RDS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ltpayments
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSL=false

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_API_VERSION=2023-10-16

# GraphQL / Mesh
GRAPHQL_PORT=4001
HIVE_GATEWAY_URL=http://localhost:4002/graphql

# Feature Flags
ENABLE_VENDOR_ONBOARDING_GUARD=true

# Logging
LOG_LEVEL=info

# Internal Service Auth
INTERNAL_SERVICE_TOKEN=changeme
