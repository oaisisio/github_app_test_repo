# Application
NODE_ENV=development
APP_PORT=4000
SERVICE_NAME=ltpayments
LOG_LEVEL=info

# Database (RDS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ltpayments_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Stripe
STRIPE_API_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# GraphQL / Hive Gateway
GRAPHQL_MESH_GATEWAY_URL=http://localhost:4001/graphql
GRAPHQL_ENDPOINT=/graphql

# Metrics / Instrumentation
METRICS_ENABLED=true
METRICS_ENDPOINT=http://localhost:9090

# Feature Flags
ENABLE_STRIPE_ONBOARDING_CHECK=true
PAYMENT_UPDATE_LISTING_RATE_LIMIT=10
